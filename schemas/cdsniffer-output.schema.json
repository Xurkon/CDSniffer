{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/cdsniffer-output.schema.json",
  "title": "CDSniffer Output",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp",
    "region_count",
    "hit_count",
    "unique_hit_count",
    "top_hits",
    "regions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "region_count": {
      "type": "integer",
      "minimum": 0
    },
    "hit_count": {
      "type": "integer",
      "minimum": 0
    },
    "unique_hit_count": {
      "type": "integer",
      "minimum": 0
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "process": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["once", "loop", "hotkey"]
    },
    "label": {
      "type": "string"
    },
    "hotkey": {
      "type": "string"
    },
    "top_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["encoding", "text", "count", "first_address"],
        "properties": {
          "encoding": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "first_address": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["base_address", "region_size", "hits"],
        "properties": {
          "base_address": {
            "type": "integer",
            "minimum": 0
          },
          "region_size": {
            "type": "integer",
            "minimum": 0
          },
          "allocation_base": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "allocation_protect": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "allocation_protection": {
            "type": ["string", "null"]
          },
          "state": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "state_name": {
            "type": ["string", "null"]
          },
          "protect": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "protection": {
            "type": ["string", "null"]
          },
          "type": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "type_name": {
            "type": ["string", "null"]
          },
          "module": {
            "type": ["object", "null"],
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "base_address": {
                "type": "integer",
                "minimum": 0
              },
              "size": {
                "type": "integer",
                "minimum": 0
              },
              "end_address": {
                "type": "integer",
                "minimum": 0
              },
              "entry_point": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "hits": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["address", "encoding", "text"],
              "properties": {
                "address": {
                  "type": "integer",
                  "minimum": 0
                },
                "region_offset": {
                  "type": "integer",
                  "minimum": 0
                },
                "module_rva": {
                  "type": ["integer", "null"],
                  "minimum": 0
                },
                "encoding": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "raw_size": {
                  "type": "integer",
                  "minimum": 0
                },
                "context": {
                  "type": ["object", "null"],
                  "properties": {
                    "window_address": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "window_size": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "hit_offset": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "hit_size": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "bytes_before": {
                      "type": "string"
                    },
                    "hit_bytes": {
                      "type": "string"
                    },
                    "bytes_after": {
                      "type": "string"
                    },
                    "hex": {
                      "type": "string"
                    },
                    "ascii": {
                      "type": "string"
                    },
                    "numeric_candidates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["address", "relative_offset", "size", "endian", "value", "hex"],
                        "properties": {
                          "address": {
                            "type": "integer",
                            "minimum": 0
                          },
                          "relative_offset": {
                            "type": "integer"
                          },
                          "size": {
                            "type": "integer",
                            "enum": [2, 4, 8]
                          },
                          "endian": {
                            "type": "string",
                            "enum": ["little", "big"]
                          },
                          "value": {
                            "type": "integer",
                            "minimum": 1
                          },
                          "hex": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
